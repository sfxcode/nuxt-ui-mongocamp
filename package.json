{
  "name": "@sfxcode/nuxt-ui-mongocamp",
  "version": "1.2.2",
  "description": "A Nuxt module that wraps @sfxcode/nuxt-mongocamp-server with ready-made UI components, composables, and a runtime plugin",
  "repository": "sfxcode/nuxt-ui-mongocamp",
  "homepage": "https://sfxcode.github.io/nuxt-ui-mongocamp/",
  "bugs": "https://github.com/sfxcode/nuxt-ui-mongocamp/issues",
  "author": "sfxcode",
  "license": "MIT",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "mongocamp",
    "mongodb",
    "vue",
    "nuxt-ui"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --patch --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run --project unit --project components",
    "test:watch": "vitest watch",
    "test:e2e:auth": "vitest run --project e2e-auth",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@formkit/nuxt": "^2.1.0",
    "@internationalized/date": "^3.12.2",
    "@nuxt/ui": "^4.10.0",
    "@nuxtjs/i18n": "^10.4.1",
    "@sfxcode/nuxt-mongocamp-server": "^1.5.0",
    "@sfxcode/nuxt-ui-formkit": "^1.2.8",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "minimatch": "^10.2.5",
    "unocss-nuxt-ui": "^1.2.2"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.118",
    "@nuxt/devtools": "4.0.0-alpha.7",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/kit": "^4.5.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.5.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@vue/test-utils": "^2.4.11",
    "@unhead/vue": "^3.1.8",
    "changelogen": "^0.6.2",
    "eslint": "^10.7.0",
    "happy-dom": "^20.11.0",
    "nuxt": "^4.5.0",
    "typescript": "~6.0.3",
    "vitepress": "2.0.0-alpha.18",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
